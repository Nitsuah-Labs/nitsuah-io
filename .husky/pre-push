#!/bin/sh
# Add Node.js to PATH for Git Bash on Windows
export PATH="/c/Program Files/nodejs:$PATH"

echo "🔍 Running pre-push validation..."

# Type check
echo "1/3 Type checking..."
npm run typecheck || exit 1

# Run unit tests
echo "2/3 Running unit tests..."
npm test || {
	echo "⚠️  Tests failed. Please fix them before pushing."
	exit 1
}

# E2E tests are intentionally skipped here — they run in CI (GitHub Actions)
# against the production build. Running them locally on every push is too
# slow and depends on env-specific setup (ports, browsers, etc.).
echo "3/3 Skipping E2E (runs in CI) — all pre-push checks passed!"

echo "✅ Pre-push checks passed! Your code is ready for CI."
