#!/bin/sh
echo "Running pre-commit validation..."

REPO_ROOT="$(git rev-parse --show-toplevel)"
DOCKER_RUN="docker run --rm -v ${REPO_ROOT}:/app -v nitsuah-io-node-modules:/app/node_modules -w /app node:22.13.0-slim"

# Step 1: Type checking
echo "1/4 Checking types..."
$DOCKER_RUN sh -c "npm ci --legacy-peer-deps --prefer-offline && npm run typecheck" || exit 1

# Step 2: Linting
echo "2/4 Running linter..."
$DOCKER_RUN sh -c "npm run lint" || echo "Lint errors found."

# Step 3: Auto-formatting staged files and re-staging
echo "3/4 Auto-formatting staged files..."
$DOCKER_RUN sh -c "npm run format" && git add -A

# Step 4: Jest unit tests
echo "4/4 Running Jest tests..."
$DOCKER_RUN sh -c "npm test" || {
  echo "Tests failed. Please fix them before committing."
  exit 1
}

echo "All pre-commit checks passed!"
